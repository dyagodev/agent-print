{
  "name": "kero-pedir-print-agent",
  "version": "1.0.0",
  "description": "Agente local de impressão para o Kero Pedir",
  "main": "electron/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "start:win": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.keropedir.print-agent",
    "productName": "Kero Pedir Print",
    "copyright": "Kero Pedir",
    "publish": {
      "provider": "github",
      "owner": "dyagodev",
      "repo": "agent-print",
      "releaseType": "release"
    },
    "files": [
      "electron/**/*",
      "core/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
